# Скопируйте в .env и подставьте значения (файл .env в git не коммитится).
# cp .env.example .env

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# ID чата или группы (часто отрицательное число для групп)
TELEGRAM_CHAT_ID=

# Куда слать письмо с заявкой (один адрес)
LEAD_EMAIL_TO=

# Отправитель писем (опционально; иначе подставится no-reply@ваш-домен)
# MAIL_FROM=no-reply@example.com
